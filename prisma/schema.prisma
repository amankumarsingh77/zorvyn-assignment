generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VIEWER
  ANALYST
  ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
}

enum RecordType {
  INCOME
  EXPENSE
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(VIEWER)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  records Record[]

  @@map("users")
}

model Record {
  id        String     @id @default(uuid())
  amount    Decimal    @db.Decimal(12, 2)
  type      RecordType
  category  String
  date      DateTime
  notes     String?
  createdBy String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  creator User @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([type, date])
  @@map("records")
}
